# =======================================================================
# DocuMind — Environment Variables Template
# =======================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value in .env
#   3. NEVER commit .env to Git — it contains real secrets
# =======================================================================

# -----------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------
# SECRET_KEY: A long random string Django uses for security (encryption,
# session tokens, etc). Generate one at: https://djecrety.ir
SECRET_KEY=your-long-random-secret-key-here

# DEBUG: True shows detailed error pages. ALWAYS set to False in production.
DEBUG=True

# ALLOWED_HOSTS: Which domain names can access this app.
ALLOWED_HOSTS=localhost,127.0.0.1

# LOG_LEVEL: DEBUG (local) | INFO (staging) | WARNING (production)
LOG_LEVEL=DEBUG

# LOG_FORMAT: verbose (local) | json (staging + production)
# "verbose" → human-readable text for your terminal: [timestamp] LEVEL name [request_id] - message
# "json"    → machine-parseable JSON for Datadog/CloudWatch: {"timestamp":...,"level":...}
LOG_FORMAT=verbose

# -----------------------------------------------------------------------
# Database — PostgreSQL (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://documind:documind@localhost:5432/documind

# -----------------------------------------------------------------------
# Cache + Task Queue — Redis (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------
# File Storage — MinIO (local fake S3)
# For production: replace with real AWS S3 credentials
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=documind
AWS_SECRET_ACCESS_KEY=documind123
AWS_STORAGE_BUCKET_NAME=documind-documents
# Local MinIO endpoint — remove this line when switching to real AWS S3
AWS_S3_ENDPOINT_URL=http://localhost:9000

# -----------------------------------------------------------------------
# LLM Providers
# At least one provider must be configured, or Ollama must be enabled.
# Fallback chain (when model= is omitted): OpenAI → Anthropic → Bedrock → Ollama
# -----------------------------------------------------------------------

# OpenAI — get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude — get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# AWS Bedrock — Claude on AWS (data stays in your AWS VPC)
# NOTE: These are separate from the MinIO storage credentials above.
# Enable model access first: AWS Console → Bedrock → Model access
BEDROCK_ENABLED=false
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Ollama — free local fallback, no API key needed
# Default is false — requires explicit opt-in to avoid cryptic errors if Ollama is not running.
# Set to true only after: docker compose up -d ollama && docker compose exec ollama ollama pull qwen2.5:3b
# qwen2.5:3b is recommended over llama3.2 — it reliably follows JSON schemas for the agent pipeline.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# Agent pipeline LLM provider (Phase 5 /analysis/ endpoint).
# "ollama"  → use Ollama (default when OLLAMA_ENABLED=true — no cloud keys needed)
# "openai"  → use OpenAI even when Ollama is enabled (set alongside a real OPENAI_API_KEY)
# This is independent of Phase 4 which always uses all configured providers.
AGENT_LLM_PROVIDER=ollama

# -----------------------------------------------------------------------
# LLM Tuning
# -----------------------------------------------------------------------
# Temperature: 0.0 = focused/deterministic, 1.0 = creative. Keep low for RAG.
DOCUMIND_LLM_TEMPERATURE=0.1
DOCUMIND_LLM_MAX_TOKENS=1024
# Local Ollama (qwen2.5:3b) needs ~30-60s to produce first token after a cold start.
# Set to 90.0 when using Ollama; 30.0 is fine for OpenAI/Anthropic (they respond in <5s).
# Local Ollama (qwen2.5:3b) needs ~30-60s to produce first token after a cold start.
# Set to 90.0 when using Ollama; 30.0 is fine for OpenAI/Anthropic (they respond in <5s).
DOCUMIND_LLM_TIMEOUT_SECONDS=90.0
# Max document context tokens sent to LLM. Chunks are trimmed if exceeded.
DOCUMIND_MAX_CONTEXT_TOKENS=6000

# -----------------------------------------------------------------------
# Retrieval tuning (safe to leave at defaults for local dev)
# -----------------------------------------------------------------------
# Cross-encoder model downloaded from HuggingFace (~70MB) for reranking.
# Must be a sentence-transformers compatible cross-encoder model.
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# How many candidates (k * multiplier) are passed to the reranker.
# Higher = better recall, more reranker latency. Default 3 is a good balance.
RETRIEVAL_CANDIDATE_MULTIPLIER=3

# Enable NLTK Porter stemming + English stopword removal for BM25 keyword search.
# false (default) = whitespace tokenizer, zero extra latency, existing cache valid.
# true = better recall on synonym-heavy queries (e.g. "legal" matches "legally").
# IMPORTANT: bump _BM25_CACHE_KEY_PREFIX in documents/services.py to v2 before
# enabling so stale non-stemmed Redis indexes are rebuilt with the new tokenizer.
BM25_USE_STEMMING=false

# -----------------------------------------------------------------------
# Semantic cache tuning
# -----------------------------------------------------------------------
# Cosine similarity threshold for a cache hit (0.0–1.0).
# 0.92 is a good default. Raise to 0.95+ for legal/compliance documents
# where even slight paraphrasing must trigger a fresh LLM call.
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92

# How many days to keep cached answers before expiring them.
SEMANTIC_CACHE_TTL_DAYS=7

# -----------------------------------------------------------------------
# Prompt versioning
# -----------------------------------------------------------------------
# Active system prompt version (see generation/prompts.py for available versions).
# Change per-environment to A/B test prompts without a code deployment.
DOCUMIND_PROMPT_VERSION=v1

# -----------------------------------------------------------------------
# Agent pipeline tuning (safe to leave at defaults for local dev)
# -----------------------------------------------------------------------
# Max tokens for LLM generation inside agent nodes.
# 1000 is sized for local Ollama (qwen2.5:3b ≈ 9 tok/s ≈ 111s generation).
# These limits are never reached with production OpenAI (200 tok/s).
AGENT_SYNTHESIS_MAX_TOKENS=1000
AGENT_SUBQUERY_MAX_TOKENS=1000

# Chunks retrieved per sub-question in multi-hop workflows.
AGENT_RETRIEVAL_K=5

# -----------------------------------------------------------------------
# Flower — Celery monitoring dashboard (http://localhost:5555)
# -----------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------
# LangSmith — LLM Observability (optional, set LANGCHAIN_TRACING_V2=false to disable)
# Sign up free at: https://smith.langchain.com
# When disabled, @traceable decorators are a no-op — zero performance impact.
# -----------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=documind

# -----------------------------------------------------------------------
# Evaluation Framework (Phase 6)
# -----------------------------------------------------------------------
# RAGAS judge provider — which LLM scores the RAG outputs (faithfulness, relevancy, recall).
# Follows the same pattern as AGENT_LLM_PROVIDER:
#   "ollama"  → use local Ollama (no API key needed — good for local dev)
#   "openai"  → use OpenAI gpt-4o-mini (better scoring quality, requires OPENAI_API_KEY)
# Defaults to "ollama" when OLLAMA_ENABLED=true, otherwise "openai".
RAGAS_JUDGE_PROVIDER=ollama

# Which Ollama model to use as the RAGAS judge (only used when RAGAS_JUDGE_PROVIDER=ollama).
# Must be pulled first: docker compose exec ollama ollama pull qwen2.5:3b
RAGAS_OLLAMA_MODEL=qwen2.5:3b

# OpenAI model for RAGAS judge (only used when RAGAS_JUDGE_PROVIDER=openai).
# gpt-4o-mini is accurate enough for scoring and much cheaper than gpt-4o.
RAGAS_LLM_MODEL=gpt-4o-mini

# Path to the ground-truth Q&A dataset (relative to project root)
EVAL_DATASET_PATH=data/eval/qa_pairs.json
