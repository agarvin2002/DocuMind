# =======================================================================
# DocuMind — Environment Variables Template
# =======================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value in .env
#   3. NEVER commit .env to Git — it contains real secrets
# =======================================================================

# -----------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------
# SECRET_KEY: A long random string Django uses for security (encryption,
# session tokens, etc). Generate one at: https://djecrety.ir
SECRET_KEY=your-long-random-secret-key-here

# DEBUG: True shows detailed error pages. ALWAYS set to False in production.
DEBUG=True

# ALLOWED_HOSTS: Which domain names can access this app.
ALLOWED_HOSTS=localhost,127.0.0.1

# LOG_LEVEL: DEBUG (local) | INFO (staging) | WARNING (production)
LOG_LEVEL=DEBUG

# LOG_FORMAT: verbose (local) | json (staging + production)
# "verbose" → human-readable text for your terminal: [timestamp] LEVEL name [request_id] - message
# "json"    → machine-parseable JSON for Datadog/CloudWatch: {"timestamp":...,"level":...}
LOG_FORMAT=verbose

# -----------------------------------------------------------------------
# Database — PostgreSQL (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://documind:documind@localhost:5432/documind

# -----------------------------------------------------------------------
# Cache + Task Queue — Redis (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------
# File Storage — MinIO (local fake S3)
# For production: replace with real AWS S3 credentials
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=documind
AWS_SECRET_ACCESS_KEY=documind123
AWS_STORAGE_BUCKET_NAME=documind-documents
# Local MinIO endpoint — remove this line when switching to real AWS S3
AWS_S3_ENDPOINT_URL=http://localhost:9000

# -----------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------
# OpenAI — get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key-here

# Anthropic Claude — get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here

# -----------------------------------------------------------------------
# LangSmith — LLM Observability (optional but recommended)
# Sign up free at: https://smith.langchain.com
# -----------------------------------------------------------------------
LANGCHAIN_API_KEY=ls__...your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=documind
